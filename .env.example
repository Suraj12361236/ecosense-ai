# Copy this file to .env (for local dev) and fill in real values.
# Vercel/Netlify: set these in your project's Environment Variables settings instead.

# Used by api/claude.js (server-side only — never put real keys in VITE_ vars)
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: if you deploy the API proxy somewhere other than /api/claude
# (e.g. a separate backend service), set its full URL here.
# VITE_CLAUDE_API_URL=https://your-backend.example.com/api/claude
